{
  "name": "estv-desktop",
  "version": "0.1.3",
  "description": "ESTV desktop interpreter — invisible captions + Google Meet voice interpreting",
  "main": "main.js",
  "author": "ESTV",
  "license": "UNLICENSED",
  "repository": { "type": "git", "url": "https://github.com/makewayyourself/estv.git" },
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "^31.7.6",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.estv.desktop",
    "productName": "ESTV Interpreter",
    "files": ["main.js", "preload.js"],
    "publish": [{ "provider": "github", "owner": "makewayyourself", "repo": "estv" }],
    "win": {
      "target": ["nsis"],
      "artifactName": "ESTV-Interpreter-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}

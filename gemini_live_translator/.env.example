# ----------------------------------------------------------------------------
# Gemini Live Translator — environment configuration
# Copy this file to ".env" and fill in your values.
# ----------------------------------------------------------------------------

# Your Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Live model to use.
#   gemini-3.5-live-translate-preview  (DEFAULT) dedicated low-latency speech-to-
#                                      speech translation, 70+ languages, public
#                                      preview (~$0.023/min, needs billing).
#                                      Source is auto-detected; set the language
#                                      you want to HEAR via the app's Language B.
#   gemini-2.0-flash-exp               persona-based two-way interpreting with a
#                                      selectable prebuilt voice (no billing needed
#                                      for the free tier); good fallback.
GEMINI_LIVE_MODEL=gemini-3.5-live-translate-preview

# Text models for the non-realtime helpers (2.0-flash family was shut down
# 2026-06-01; these are current as of June 2026).
#   RISK_MODEL    risk-only per-turn check → fast/cheap "Lite":
#                 gemini-3.1-flash-lite (default) or gemini-2.5-flash-lite
#   CLARIFY_MODEL meaning-clarification reasoning (and any turn with Clarify on)
#                 → stronger: gemini-3.5-flash (default)
#   SUMMARY_MODEL whole-transcript summary / Q&A → gemini-3.5-flash (default)
RISK_MODEL=gemini-3.1-flash-lite
CLARIFY_MODEL=gemini-3.5-flash
SUMMARY_MODEL=gemini-3.5-flash

# Extra reasoning ("thinking") budget in tokens for the clarification/analysis
# path. Higher = stronger reasoning, a bit more cost/latency (off the realtime
# path). Set 0 to disable.
ANALYSIS_THINKING_BUDGET=4096

# Prebuilt voice for the synthesized translation. Options include:
#   Aoede, Puck, Charon, Kore, Fenrir, Leda, Orus, Zephyr
GEMINI_VOICE=Aoede

# Access token that gates the /api/stream WebSocket. STRONGLY RECOMMENDED for
# any public deployment: without it, anyone who learns your server URL can spend
# your Gemini quota. The client must connect with ?token=<this value>. Leave
# blank to disable auth (local development only).
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
ACCESS_TOKEN=

# Host / port for the local server
HOST=0.0.0.0
PORT=8000

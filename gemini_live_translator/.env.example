# ----------------------------------------------------------------------------
# Gemini Live Translator — environment configuration
# Copy this file to ".env" and fill in your values.
# ----------------------------------------------------------------------------

# Your Google Gemini API key. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Live model to use. Must be a model that supports the bidirectional Live API
# with native audio output. Sensible options (availability changes over time):
#   gemini-2.0-flash-exp                       (widely available, good default)
#   gemini-live-2.5-flash-preview              (newer half-cascade live model)
#   gemini-2.5-flash-preview-native-audio-dialog
GEMINI_LIVE_MODEL=gemini-2.0-flash-exp

# Prebuilt voice for the synthesized translation. Options include:
#   Aoede, Puck, Charon, Kore, Fenrir, Leda, Orus, Zephyr
GEMINI_VOICE=Aoede

# Host / port for the local server
HOST=0.0.0.0
PORT=8000
